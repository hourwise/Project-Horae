{
  "name": "horae",
  "version": "0.1.0",
  "private": true,
  "description": "Project Horae - session and capability orchestrator for governed AI runtimes",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint packages --ext .ts",
    "format": "prettier --write .",
    "dev:cli": "npm run dev -w @horae/cli",
    "test:bench": "npm run test -w @horae/testbench"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
